        # Calculate total seconds for easier time calculations (clock counts down)
        bucknell_plays <- bucknell_plays %>%
          mutate(
            total_seconds = clock_minutes * 60 + clock_seconds
          )
        
        # Identify possession-ending events
        cat("Identifying possession-ending events...\n")
        bucknell_plays <- bucknell_plays %>%
          mutate(
            # Check if this is a turnover
            is_turnover = grepl("turnover|Turnover", type_text, ignore.case = TRUE),
            
            # Check if this is a defensive rebound (using actual type_text)
            is_defensive_rebound = grepl("Defensive Rebound", type_text, ignore.case = TRUE),
            
            # Possession ends on: made shot, defensive rebound, or turnover
            possession_ends = (shooting_play == TRUE & scoring_play == TRUE) |  # Made shot
              is_defensive_rebound |                             # Defensive rebound
              is_turnover                                        # Turnover
          )
        
        # Create possession IDs based on actual possession endings
        # CRITICAL: Do this separately for each game AND period
        cat("Creating possession boundaries...\n")
        bucknell_plays <- bucknell_plays %>%
          group_by(game_id, period_number) %>%
          arrange(game_id, game_play_number) %>%  # Sort by game_play_number within group
          mutate(
            # New possession starts AFTER the previous play ended a possession
            prev_possession_ended = lag(possession_ends, default = FALSE),
            new_possession = prev_possession_ended | (row_number() == 1),
            possession_id_within_period = cumsum(new_possession)
          ) %>%
          ungroup() %>%
          # Create unique possession_id across all games/periods
          group_by(game_id) %>%
          mutate(
            possession_id = cumsum(new_possession | (row_number() == 1))
          ) %>%
