   if(!"player_1" %in% colnames(lineup_df)) {
     lineup_df <- parse_lineup_players(lineup_df)
   }
   
   # Join jersey numbers for each player position
   lineup_with_jerseys <- lineup_df
   
   for(i in 1:5) {
     player_col <- paste0("player_", i)
     jersey_col <- paste0("jersey_", i)
     position_col <- paste0("position_", i)
     
     # Create temporary join
     temp_join <- roster_df %>%
       select(PLAYER, NUM, POSITION) %>%
       rename(!!jersey_col := NUM,
              !!position_col := POSITION)
     
     lineup_with_jerseys <- lineup_with_jerseys %>%
       left_join(temp_join, 
                 by = setNames("PLAYER", player_col))
   }
   
   return(lineup_with_jerseys)
 }
 
