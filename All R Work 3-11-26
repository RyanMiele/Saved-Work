 # Function to calculate weighted correlation
 weighted_cor <- function(x, y, weights) {
   # Remove rows where x, y, or weights are NA
   valid_rows <- !is.na(x) & !is.na(y) & !is.na(weights) & weights > 0
   x <- x[valid_rows]
   y <- y[valid_rows]
   weights <- weights[valid_rows]
   
   if(length(x) < 2) return(NA)
   
   # Calculate weighted means
   weighted_mean_x <- sum(x * weights) / sum(weights)
   weighted_mean_y <- sum(y * weights) / sum(weights)
   
   # Calculate weighted covariance and variances
   weighted_cov <- sum(weights * (x - weighted_mean_x) * (y - weighted_mean_y)) / sum(weights)
   weighted_var_x <- sum(weights * (x - weighted_mean_x)^2) / sum(weights)
   weighted_var_y <- sum(weights * (y - weighted_mean_y)^2) / sum(weights)
   
   # Calculate correlation
   weighted_correlation <- weighted_cov / sqrt(weighted_var_x * weighted_var_y)
   return(weighted_correlation)
 }
 
 
