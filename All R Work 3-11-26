 # Function to get lineups across multiple seasons
 get_historical_lineups <- function(start_year, end_year, season_type = "Regular Season") {
   
   all_seasons <- list()
   
   for(year in start_year:end_year) {
     season_str <- paste0(year, "-", substr(year + 1, 3, 4))
     cat("\nProcessing season:", season_str, "\n")
     
     tryCatch({
       season_lineups <- get_all_team_lineups(
         season = season_str,
         season_type = season_type
       )
       
       season_lineups$SEASON <- season_str
       all_seasons[[season_str]] <- season_lineups
       
       # Longer delay between seasons
       Sys.sleep(2)
       
     }, error = function(e) {
       message(paste("Error processing season", season_str, ":", e$message))
     })
   }
   
   # Combine all seasons
   historical_data <- bind_rows(all_seasons)
   
   return(historical_data)
 }
 
