 # Function to get lineup data from NBA.com API
 get_nba_lineups <- function(season = "2023-24", 
                             season_type = "Regular Season",
                             group_quantity = 5,
                             team_id = NULL) {
   
   # NBA.com API endpoint for lineups
   base_url <- "https://stats.nba.com/stats/leaguedashlineups"
   
   # Map season type
   season_type_map <- list(
     "Regular Season" = "Regular Season",
     "Playoffs" = "Playoffs",
     "All Star" = "All Star"
   )
   
   # Parameters for the API call
   params <- list(
     GroupQuantity = group_quantity,  # 5 for 5-man lineups
     Season = season,
     SeasonType = season_type_map[[season_type]],
     MeasureType = "Base",
     PerMode = "Totals",
     PlusMinus = "N",
     PaceAdjust = "N",
     Rank = "N",
     Outcome = "",
     Location = "",
     Month = 0,
     SeasonSegment = "",
     DateFrom = "",
     DateTo = "",
     OpponentTeamID = 0,
     VsConference = "",
     VsDivision = "",
     GameSegment = "",
     Period = 0,
     LastNGames = 0
   )
   
   # Add team filter if specified
   if(!is.null(team_id)) {
     params$TeamID <- team_id
   } else {
     params$TeamID <- 0
   }
   
   # Required headers for NBA.com API
   headers <- c(
     'User-Agent' = 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
     'Accept' = 'application/json, text/plain, */*',
     'Accept-Language' = 'en-US,en;q=0.5',
     'Referer' = 'https://www.nba.com/',
     'Origin' = 'https://www.nba.com',
     'Connection' = 'keep-alive'
   )
   
   # Make the API request
   response <- GET(
     url = base_url,
     query = params,
     add_headers(.headers = headers)
   )
   
   # Check if request was successful
   if(status_code(response) != 200) {
     stop(paste("API request failed with status code:", status_code(response)))
   }
   
   # Parse JSON response
   content <- content(response, "text", encoding = "UTF-8")
   data <- fromJSON(content)
   
   # Extract the lineup data
   if(length(data$resultSets$rowSet) > 0) {
     lineup_data <- data$resultSets$rowSet[[1]]
     column_names <- data$resultSets$headers[[1]]
     
     # Convert to data frame
     lineup_df <- as.data.frame(lineup_data, stringsAsFactors = FALSE)
     colnames(lineup_df) <- column_names
     
     # Clean up data types
     numeric_cols <- c("MIN", "GP", "W", "L", "W_PCT", "FGM", "FGA", "FG_PCT", 
                       "FG3M", "FG3A", "FG3_PCT", "FTM", "FTA", "FT_PCT",
                       "OREB", "DREB", "REB", "AST", "TOV", "STL", "BLK",
                       "BLKA", "PF", "PFD", "PTS", "PLUS_MINUS")
     
     for(col in numeric_cols) {
       if(col %in% colnames(lineup_df)) {
         lineup_df[[col]] <- as.numeric(lineup_df[[col]])
       }
     }
     
     return(lineup_df)
   } else {
     warning("No lineup data returned")
     return(NULL)
   }
 }
 
