       # Function to check if a point is within a passing lane
       is_in_passing_lane <- function(puck_x, puck_y, target_x, target_y, defender_x, defender_y, width = 3) {
         dx <- target_x - puck_x
         dy <- target_y - puck_y
         lane_length <- sqrt(dx^2 + dy^2)
         
         ux <- dx / lane_length
         uy <- dy / lane_length
         
         pdx <- defender_x - puck_x
         pdy <- defender_y - puck_y
         
         projection <- pdx * ux + pdy * uy
         perp_distance <- abs(pdx * uy - pdy * ux)
         
         projection > 0 & projection < lane_length & perp_distance <= width
       }
       
