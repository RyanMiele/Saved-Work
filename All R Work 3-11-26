        # ── Helper: standard NBA API GET ──────────────────────────────────────────────
        nba_get <- function(endpoint, params) {
          request(paste0("https://stats.nba.com/stats/", endpoint)) %>%
            req_headers(
              "Referer"            = "https://www.nba.com/",
              "User-Agent"         = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
              "x-nba-stats-origin" = "stats",
              "x-nba-stats-token"  = "true"
            ) %>%
            req_url_query(!!!params) %>%
            req_perform() %>%
            resp_body_json()
        }
        
        # ── Helper: parse NBA API response into a dataframe ───────────────────────────
        parse_nba <- function(data, result_set = 1) {
          rows <- data$resultSets[[result_set]]$rowSet
          cols <- data$resultSets[[result_set]]$headers
          
          if (length(rows) == 0) return(NULL)
          
          do.call(rbind, lapply(rows, function(x) {
            x[sapply(x, is.null)] <- NA
            as.data.frame(x, stringsAsFactors = FALSE)
          })) %>%
            setNames(cols)
        }
        
        # ── Step 1: Get all game IDs for a season ─────────────────────────────────────
        get_season_game_ids <- function(season = "2023-24", season_type = "Regular Season") {
          data <- nba_get("leaguegamelog", list(
            Counter      = 0,
            Direction    = "ASC",
            LeagueID     = "00",
            PlayerOrTeam = "T",
            Season       = season,
            SeasonType   = season_type,
            Sorter       = "DATE"
          ))
          
          unique(parse_nba(data)$GAME_ID)
        }
        
        # ── Step 2: Get rotation data for one game ────────────────────────────────────
        get_game_rotation <- function(game_id) {
          data <- nba_get("gamerotation", list(GameID = game_id, LeagueID = "00"))
          
          home <- parse_nba(data, result_set = 1) %>% mutate(SIDE = "home")
          away <- parse_nba(data, result_set = 2) %>% mutate(SIDE = "away")
          
          bind_rows(home, away)
        }
        
        # ── Step 3: Get play by play ──────────────────────────────────────────────────
        get_pbp <- function(game_id) {
          data <- nba_get("playbyplayv2", list(
            GameID      = game_id,
            StartPeriod = 0,
            EndPeriod   = 0
          ))
          parse_nba(data)
        }
        
        # ── Step 4: Convert PBP clock to elapsed tenths of a second ──────────────────
        pbp_to_elapsed <- function(period, clock) {
          parts     <- strsplit(clock, ":")
          mins      <- as.numeric(sapply(parts, `[`, 1))
          secs      <- as.numeric(sapply(parts, `[`, 2))
          time_left <- mins * 60 + secs
          
          period_start <- ifelse(period <= 4,
                                 (period - 1) * 720,
                                 4 * 720 + (period - 5) * 300)
          period_len   <- ifelse(period <= 4, 720, 300)
          
          (period_start + (period_len - time_left)) * 10
        }
        
        # ── Step 5: Get 5 players on court for a side at each elapsed time ────────────
        get_oncourt_side <- function(elapsed_vec, rotation_df) {
          result <- sapply(elapsed_vec, function(e) {
            players <- rotation_df %>%
              filter(IN_TIME <= e, OUT_TIME > e) %>%
              pull(PLAYER_ID)
            length(players) <- 5  # pad to 5 if fewer found
            players
          })
          t(result) %>%
            as.data.frame() %>%
            setNames(paste0("player_", 1:5))
        }
        
        # ── Step 6: Combine rotation + PBP to get 10 players on court ────────────────
        get_oncourt_10 <- function(game_id) {
          message("Processing game: ", game_id)
          
          pbp <- tryCatch(get_pbp(game_id),            error = function(e) NULL)
          rot <- tryCatch(get_game_rotation(game_id),   error = function(e) NULL)
          
          if (is.null(pbp) || is.null(rot)) {
            message("  Skipping — no data returned")
            return(NULL)
          }
          
          rot <- rot %>%
            mutate(
              IN_TIME  = as.numeric(IN_TIME_REAL),
              OUT_TIME = as.numeric(OUT_TIME_REAL)
            )
          
          pbp <- pbp %>%
            mutate(ELAPSED = pbp_to_elapsed(as.numeric(PERIOD), PCTIMESTRING))
          
          home_rot <- rot %>% filter(SIDE == "home")
          away_rot <- rot %>% filter(SIDE == "away")
          
          home_players <- get_oncourt_side(pbp$ELAPSED, home_rot)
          away_players <- get_oncourt_side(pbp$ELAPSED, away_rot)
          
          colnames(home_players) <- paste0("home_player_", 1:5)
          colnames(away_players) <- paste0("away_player_", 1:5)
          
          bind_cols(pbp, home_players, away_players)
        }
        
