condensed_pbp <- total_pbp%>%
  mutate(is_free_throw = if_else(grepl("Free Throw",type_text), 1,0),
         is_three = if_else(grepl("three point",text), 1,0),
         is_rim = if_else(grepl("Layup",type_text) | grepl("Dunk",type_text)|
                            grepl("Tip Shot",type_text),1,0),
         is_mid_range = if_else(is_rim == 0 & is_three == 0,1,0),
         zone = case_when(is_rim == 1 ~ "Rim",
                          is_mid_range == 1 ~ "Mid Range",
                          is_three == 1 ~ "3P"),
         pd = abs(home_score - away_score))%>%
  filter(season_type == 2 & 
           is_free_throw == 0 &
           shooting_play == TRUE & 
           qtr <= 4 &
           pd <= 5)%>%
  mutate(long_time = case_when(qtr == 1 ~ clock_minutes + 36,
                               qtr == 2 ~ clock_minutes + 24,
                               qtr == 3 ~ clock_minutes + 12,
                               qtr == 4 ~ clock_minutes))%>%
  reframe(time,period,period_number,clock_minutes,long_time,type_text,text,is_rim,is_mid_range,is_three,zone,pd)


