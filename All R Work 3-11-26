# Function to predict impact for a grid of measurements
predict_grid_impact <- function(grid_df, base_player) {
  # Create template dataframe with all needed features
  predictions <- numeric(nrow(grid_df))
  
  for(i in 1:nrow(grid_df)) {
    # Create temporary player with new measurements
    temp_player <- base_player
    temp_player$HEIGHT_WO_SHOES.y <- grid_df$HEIGHT_WO_SHOES.y[i]
    temp_player$WINGSPAN <- grid_df$WINGSPAN[i]
    
    # Predict impact
    pred_matrix <- as.matrix(temp_player[, defending_model$feature_names])
    dpred <- xgb.DMatrix(pred_matrix)
    predictions[i] <- predict(defending_model, dpred)[1]
  }
  
  grid_df$predicted_impact <- predictions
  return(grid_df)
}

