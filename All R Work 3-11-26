 get_historical_player_jerseys <- function(start_year, end_year) {
   
   all_data <- list()
   
   for(year in start_year:end_year) {
     season_str <- paste0(year, "-", substr(year + 1, 3, 4))
     cat("\nProcessing season:", season_str, "\n")
     
     player_jerseys <- get_all_player_jerseys(season = season_str)
     all_data[[season_str]] <- player_jerseys
     
     Sys.sleep(2)
   }
   
   historical <- bind_rows(all_data)
   
   # Clean up the output
   player_jersey_db <- historical %>%
     select(SEASON, PLAYER_ID, PLAYER, jersey_number) %>%
     rename(
       year = SEASON,
       athlete_id = PLAYER_ID,
       athlete_name = PLAYER
     )
   
   return(player_jersey_db)
 }
 
