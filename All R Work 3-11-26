      create_stat_row <- function(stats_df, y_position, title) {
        n_stats <- nrow(stats_df)
        
        # Create text for each stat
        stat_elements <- lapply(1:n_stats, function(i) {
          x_pos <- (i - 1) / n_stats + 0.5 / n_stats
          
          list(
            # Stat label
            annotate("text", x = x_pos, y = y_position + 0.04, 
                     label = stats_df$stat[i], 
                     size = 2.5, color = "#94a3b8", fontface = "bold"),
            # Stat value
            annotate("text", x = x_pos, y = y_position, 
                     label = stats_df$value[i], 
                     size = 4, color = "white", fontface = "bold"),
            # Percentile bar
            annotate("rect", 
                     xmin = x_pos - 0.04, xmax = x_pos + 0.04,
                     ymin = y_position - 0.025, ymax = y_position - 0.02,
                     fill = get_percentile_color(stats_df$percentile[i]))
          )
        })
        
        # Add section title
        title_element <- annotate("text", x = 0.5, y = y_position + 0.08, 
                                  label = title, 
                                  size = 3, color = "#64748b", fontface = "bold")
        
