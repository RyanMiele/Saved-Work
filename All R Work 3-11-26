  find_threshold <- function(stat_column, is_win) {
    # Sort the data by the stat column
    df_sorted <- win_model[order(win_model[[stat_column]]), ]
    
    # Calculate cumulative win rate at each stat value
    df_sorted$cum_win_rate <- cumsum(df_sorted$is_win) / seq_along(df_sorted$is_win)
    
    # Find the minimum stat value that gives a 75% win rate
    threshold_row <- df_sorted[df_sorted$cum_win_rate >= 0.75, ][1, ]
    
    # Return the stat value at the threshold
    return(threshold_row[[stat_column]])
  }
  
