       library(data.table)
       
       dt <- as.data.table(reduce_tracking)
       
       # Get the puck carrier's team for each event
       puck_carrier_team <- dt[, .(puck_team = first(team_id.x)), by = .(game_id, sl_event_id)]
       dt <- dt[puck_carrier_team, on = c("game_id", "sl_event_id")]
       
       # Extract this row's player x, y, team, and player_id
       x_cols <- paste0("tracking_x_player", 1:11)
       y_cols <- paste0("tracking_y_player", 1:11)
       team_cols <- paste0("team_id.y_player", 1:11)
       player_cols <- paste0("player_id.y_player", 1:11)
       
       dt[, row_x := fcoalesce(tracking_x_player1, tracking_x_player2, tracking_x_player3,
                               tracking_x_player4, tracking_x_player5, tracking_x_player6,
                               tracking_x_player7, tracking_x_player8, tracking_x_player9,
                               tracking_x_player10, tracking_x_player11)]
       
       dt[, row_y := fcoalesce(tracking_y_player1, tracking_y_player2, tracking_y_player3,
                               tracking_y_player4, tracking_y_player5, tracking_y_player6,
                               tracking_y_player7, tracking_y_player8, tracking_y_player9,
                               tracking_y_player10, tracking_y_player11)]
       
       dt[, row_team := fcoalesce(team_id.y_player1, team_id.y_player2, team_id.y_player3,
                                  team_id.y_player4, team_id.y_player5, team_id.y_player6,
                                  team_id.y_player7, team_id.y_player8, team_id.y_player9,
                                  team_id.y_player10, team_id.y_player11)]
       
       dt[, row_player_id := fcoalesce(player_id.y_player1, player_id.y_player2, player_id.y_player3,
                                       player_id.y_player4, player_id.y_player5, player_id.y_player6,
                                       player_id.y_player7, player_id.y_player8, player_id.y_player9,
                                       player_id.y_player10, player_id.y_player11)]
       
       # Split into teammates and opponents
       teammates <- dt[row_team == puck_team & !is.na(row_x)]
       opponents <- dt[row_team != puck_team & !is.na(row_x)]
       
       # Process in chunks by game_id to reduce memory
       unique_games <- unique(teammates$game_id)
       chunk_size <- 100  # Process 100 games at a time
       
       teammate_lanes_list <- list()
       
       for (i in seq(1, length(unique_games), by = chunk_size)) {
         game_chunk <- unique_games[i:min(i + chunk_size - 1, length(unique_games))]
         
         teammates_chunk <- teammates[game_id %in% game_chunk]
         opponents_chunk <- opponents[game_id %in% game_chunk]
         
         # Join for this chunk
         lanes_chunk <- opponents_chunk[teammates_chunk, on = c("game_id", "sl_event_id"), 
                                        allow.cartesian = TRUE, nomatch = NULL]
         
         # Calculate passing lanes
         lanes_chunk[, `:=`(
           dx = i.row_x - x,
           dy = i.row_y - y,
           lane_length = sqrt((i.row_x - x)^2 + (i.row_y - y)^2),
           pdx = row_x - x,
           pdy = row_y - y
         )]
         
         lanes_chunk[, `:=`(
           ux = dx / lane_length,
           uy = dy / lane_length
         )]
         
         lanes_chunk[, `:=`(
           projection = pdx * ux + pdy * uy,
           perp_distance = abs(pdx * uy - pdy * ux)
         )]
         
         lanes_chunk[, in_lane := projection > 0 & projection < lane_length & perp_distance <= 3]
         
         # Summarize immediately to reduce memory
         teammate_lanes_chunk <- lanes_chunk[, .(
           lane_blocked = any(in_lane, na.rm = TRUE),
           blocking_player_ids = paste(row_player_id[in_lane == TRUE], collapse = ", ")
         ), by = .(game_id, sl_event_id, i.row_x, i.row_y)]
         
         teammate_lanes_list[[length(teammate_lanes_list) + 1]] <- teammate_lanes_chunk
         
         # Clean up chunk
         rm(lanes_chunk, teammates_chunk, opponents_chunk, teammate_lanes_chunk)
         gc()
         
         if (i %% 500 == 1) {
           message(paste("Processed", min(i + chunk_size - 1, length(unique_games)), "of", length(unique_games), "games"))
         }
       }
       
       # Combine all chunks
       teammate_lanes <- rbindlist(teammate_lanes_list)
       rm(teammate_lanes_list)
       gc()
       
       # Clean up empty blocking_player_ids
       teammate_lanes[blocking_player_ids == "", blocking_player_ids := NA_character_]
       
       # Summarise per event
       lane_summary <- teammate_lanes[, .(
         total_passing_lanes = .N,
         blocked_lanes = sum(lane_blocked),
         open_lanes = sum(!lane_blocked)
       ), by = .(game_id, sl_event_id)]
       
       # Shot lane calculation (also by chunks)
