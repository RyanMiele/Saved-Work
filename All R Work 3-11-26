# Function to calculate Shannon Entropy
calculate_shannon_entropy <- function(frequencies) {
  # Convert frequencies to proportions
  proportions <- frequencies / sum(frequencies)
  
  # Remove zero proportions (log of 0 is undefined)
  proportions <- proportions[proportions > 0]
  
  # Calculate Shannon Entropy
  entropy <- -sum(proportions * log2(proportions))
  
  return(entropy)
}

# Function to calculate normalized Shannon Entropy (0-1 scale)
calculate_normalized_entropy <- function(frequencies) {
  raw_entropy <- calculate_shannon_entropy(frequencies)
  
  # Maximum possible entropy for n categories
  n_categories <- length(frequencies[frequencies > 0])
  max_entropy <- log2(n_categories)
  
  # Normalize
  normalized <- raw_entropy / max_entropy
  
  return(normalized)
}






