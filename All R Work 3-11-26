         shot_lanes_chunk[, in_lane := projection > 0 & projection < lane_length & perp_distance <= 3]
         
         shot_lane_summary_chunk <- shot_lanes_chunk[, .(
           shot_lane_blocked = any(in_lane, na.rm = TRUE),
           n_defenders_blocking_shot = sum(in_lane, na.rm = TRUE),
           shot_blocking_player_ids = paste(row_player_id[in_lane == TRUE], collapse = ", ")
         ), by = .(game_id, sl_event_id)]
         
         shot_lanes_list[[length(shot_lanes_list) + 1]] <- shot_lane_summary_chunk
         
         rm(shot_lanes_chunk, shot_lane_summary_chunk)
         gc()
       }
       
       shot_lane_summary <- rbindlist(shot_lanes_list)
       rm(shot_lanes_list)
       gc()
       
       shot_lane_summary[shot_blocking_player_ids == "", shot_blocking_player_ids := NA_character_]
       
       # Join back to lane_summary
